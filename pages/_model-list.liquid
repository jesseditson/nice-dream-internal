<div
  id="model-list"
  class="hidden"
  class="flex flex-col gap-4">
  <section class="rounded-2xl border border-slate-200 bg-white/90 p-4 shadow-sm flex flex-col gap-4">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.18em] text-slate-500">Spreadsheet</p>
        <h2 class="sheet-title font-bold text-2xl">Choose a spreadsheet</h2>
        <p class="sheet-subtitle text-sm text-slate-600">Pick a spreadsheet to load your models.</p>
      </div>
      <button id="add-sheet" class="z-20 rounded-md border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">
        Create new sheet
      </button>
    </div>
    <p id="sheet-error" class="sheet-error hidden rounded-md border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700"></p>
    <ul class="sheet-list grid gap-3 md:grid-cols-2 xl:grid-cols-3">
      <li data-template="sheet-item">
        <div class="sheet-select cursor-pointer rounded-xl border border-slate-200 bg-slate-50 p-4 transition hover:border-slate-400 hover:bg-white">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="sheet-name truncate text-base font-semibold text-slate-900">Spreadsheet</div>
              <div class="sheet-meta text-sm text-slate-500">Open spreadsheet</div>
            </div>
            <a class="sheet-link rounded-md border border-slate-300 px-2 py-1 text-xs font-semibold text-slate-600 hover:bg-slate-100">Open</a>
          </div>
        </div>
      </li>
    </ul>
    <p id="no-sheets" class="hidden rounded-xl border border-dashed border-slate-300 px-4 py-6 text-center text-sm text-slate-500">
      No spreadsheets found for this Google account. Create one to get started.
    </p>
  </section>
  <section id="models-panel" class="flex flex-col gap-4 transition-opacity">
    <div class="flex justify-between items-center">
      <h2 class="title font-bold text-2xl">Models</h2>
      <button id="add-model" class="z-20">
        <i data-feather="plus-square"></i>
      </button>
    </div>
    <p id="choose-sheet-empty" class="hidden rounded-xl border border-dashed border-slate-300 px-4 py-6 text-center text-sm text-slate-500">
      Choose a spreadsheet above to view and edit models.
    </p>
    <ul class="list flex flex-col gap-2 border-t border-slate-200">
      <li data-template="list-item" class="group flex gap-4 border-slate-200 border-b relative">
        <button class="delete-model z-20 ml-4 hidden group-hover:block cursor-pointer">
          <i data-feather="trash-2"></i>
        </button>
        <button class="model cursor-pointer flex text-left flex-1 w-full items-center" title="Loading...">
          <div class="name z-10 font-bold h-24 text-xl ml-4 flex-1 justify-start flex items-center">Loading...</div>
          <div class="z-10">
            <i data-feather="chevron-right"></i>
          </div>
        </button>
        <div class="chart absolute top-0 left-0 h-24 w-full opacity-40 z-0"></div>
      </li>
    </ul>
  </section>
  <div id="add-sheet-modal" class="hidden w-full h-full top-0 left-0 fixed backdrop-blur-sm flex items-center justify-center z-20">
    <div id="modal" class="ring-gray-200 ring-1 rounded-lg p-1 overflow-hidden flex flex-col min-w-72 shadow-md bg-white">
      <h2 id="title" class="p-4 text-lg text-center font-bold text-gray-600">Create Spreadsheet</h2>
      <input
        id="new-sheet-name"
        class="px-5 py-3 border-gray-600 border-b-1"
        type="text"
        autocomplete="off"
        autofocus="true"
        placeholder="Spreadsheet Name" />
    </div>
  </div>
  <div id="add-model-modal" class="hidden w-full h-full top-0 left-0 fixed backdrop-blur-sm flex items-center justify-center z-20">
    <div id="modal" class="ring-gray-200 ring-1 rounded-lg p-1 overflow-hidden flex flex-col min-w-72 shadow-md bg-white">
      <h2 id="title" class="p-4 text-lg text-center font-bold text-gray-600">Create Model</h2>
      <input
        id="new-model-name"
        class="px-5 py-3 border-gray-600 border-b-1"
        type="text"
        autocomplete="off"
        autofocus="true"
        placeholder="Model Name" />
    </div>
  </div>
</div>
